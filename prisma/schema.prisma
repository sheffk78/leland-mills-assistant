// Prisma schema for the Leland Mills Company AI Assistant.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String?  @unique
  username  String?  @unique
  name      String
  role      String   @default("staff") // References Role.key
  // Hashed password for ADMIN and STAFF roles. Optional because DRIVERs log in with a PIN code only.
  password  String?
  // PIN code for DRIVER login. Stored hashed. Optional for ADMIN/STAFF logins.
  pinCode   String?
  createdAt DateTime @default(now())
  lastLogin DateTime?

  conversations     Conversation[]
  knowledge         KnowledgeEntry[]
  usageLogs         UsageLog[]
  userPermissions   UserPermission[]

  @@map("users")
}

model Role {
  id           String   @id @default(uuid()) @db.Uuid
  key          String   @unique           // slug: "admin", "staff", "driver", "manager", etc.
  name         String                     // Display name: "Admin", "Staff", "Driver"
  description  String?                    // What this role can do
  systemPrompt String?                    // Custom system prompt for Archie when chatting with users of this role
  isAdmin      Boolean  @default(false)   // Grants admin panel access
  isSystem     Boolean  @default(false)    // System roles cannot be deleted
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())

  rolePermissions     RolePermission[]
  skillAssignments    SkillRoleAssignment[]

  @@map("roles")
}

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@map("conversations")
}

model Message {
  id            String      @id @default(uuid()) @db.Uuid
  conversationId String     @db.Uuid
  role          String
  content       String
  createdAt     DateTime    @default(now())

  conversation Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments  FileAttachment[]

  @@index([conversationId])
  @@map("messages")
}

model FileAttachment {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @db.Uuid
  filename  String
  filepath  String
  mimetype  String
  filesize  Int
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("file_attachments")
}

model KnowledgeEntry {
  id            String   @id @default(uuid()) @db.Uuid
  question      String
  answer        String
  sourceUserId  String?  @db.Uuid
  tags          String[] @default([])
  usedCount     Int      @default(0)
  createdAt     DateTime @default(now())

  sourceUser User? @relation(fields: [sourceUserId], references: [id], onDelete: SetNull)

  @@index([sourceUserId])
  @@map("knowledge_entries")
}

model DriveFile {
  id             String    @id // Google Drive file ID (no default — assigned at sync time)
  name           String
  mimeType       String
  parentFolder   String?
  lastSyncedAt   DateTime  @default(now())

  @@map("drive_files")
}

// Rate limiting config — one row per role key. Admin can adjust via dashboard.
model UsageLimit {
  role            String   @id // role key (e.g. "admin", "staff", "driver")
  hourlyLimit     Int      @default(30)  // max messages per hour
  dailyLimit      Int      @default(100) // max messages per day
  monthlyLimit    Int      @default(2000) // max messages per month
  updatedAt       DateTime @updatedAt

  @@map("usage_limits")
}

// Per-message usage log for stats and rate limiting.
// Every chat message (user side only) gets a row here.
model UsageLog {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  role            String   // role key (references Role.key, not enforced by FK)
  conversationId  String   @db.Uuid
  source          String   @default("hermes_agent") // "hermes_agent" or "knowledge_base"
  createdAt       DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([role])
  @@index([createdAt])
  @@map("usage_logs")
}

// ---------------------------------------------------------------------------
// Permissions — granular capability keys that govern what each role/user can do
// ---------------------------------------------------------------------------

// Catalog of all known permission keys (e.g. "inventory:read", "users:manage").
// One row per permission. Seeded by scripts/migrate-permissions-skills.ts.
model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique             // e.g. "inventory:read"
  name        String                       // Human label: "Read Inventory"
  description String?                      // What this permission grants
  category    String?                      // Grouping: "Operations", "Admin", etc.
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

// Many-to-many between Role and Permission.
// A role gets a permission via an explicit allow or deny row.
// Deny rows take precedence over allow rows when evaluating permissions.
model RolePermission {
  id            String   @id @default(uuid()) @db.Uuid
  roleId        String   @db.Uuid
  permissionKey String                       // references Permission.key (not enforced by FK on key)
  effect        String   @default("allow")   // "allow" | "deny"
  createdAt     DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@unique([roleId, permissionKey])
  @@index([roleId])
  @@index([permissionKey])
  @@map("role_permissions")
}

// Direct per-user permission overrides (allow or deny).
// These take precedence over role-derived permissions.
model UserPermission {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  permissionKey String                       // references Permission.key (not enforced by FK on key)
  effect        String   @default("allow")   // "allow" | "deny"
  createdAt     DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@unique([userId, permissionKey])
  @@index([userId])
  @@index([permissionKey])
  @@map("user_permissions")
}

// ---------------------------------------------------------------------------
// Skills — reusable capabilities Archie can invoke, assignable per role
// ---------------------------------------------------------------------------

// A skill is a named, versioned capability (e.g. "inventory-search", "route-planner").
// The content is the skill body (markdown / instructions / code) stored inline.
model Skill {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique             // slug: "inventory-search"
  name        String                       // Display name
  description String?                      // What the skill does
  category    String?                      // Grouping: "Operations", "Compliance", etc.
  filePath    String?                      // Optional path to a file on disk backing this skill
  content     String? @db.Text             // Inline skill body
  isActive    Boolean  @default(true)      // Soft-disable without deleting
  isSystem    Boolean  @default(false)      // System skills cannot be deleted
  version     Int      @default(1)          // Current version number
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roleAssignments SkillRoleAssignment[]
  versions        SkillVersion[]

  @@map("skills")
}

// Which roles have which skills enabled. A skill may be assigned to many roles
// and a role may have many skills. roleKey references Role.key (not enforced by FK).
model SkillRoleAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  skillId   String   @db.Uuid
  roleKey   String                       // references Role.key
  isEnabled Boolean  @default(true)
  assignedAt DateTime @default(now())

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  role  Role  @relation(fields: [roleKey], references: [key], onDelete: Cascade)

  @@unique([skillId, roleKey])
  @@index([skillId])
  @@index([roleKey])
  @@map("skill_role_assignments")
}

// Version history for a skill. Each edit creates a new row.
model SkillVersion {
  id        String   @id @default(uuid()) @db.Uuid
  skillId   String   @db.Uuid
  version   Int                          // version number
  content   String?  @db.Text            // snapshot of skill content at this version
  createdBy String?                      // user id or "system"
  createdAt DateTime @default(now())

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, version])
  @@index([skillId])
  @@map("skill_versions")
}

// ---------------------------------------------------------------------------
// Agent profiles — maps Hermes profiles to Leland roles
// ---------------------------------------------------------------------------

// A Hermes profile (e.g. "default", "leland-staff") bound to a Leland role.
// Used to route chat sessions to the right agent configuration.
model AgentProfile {
  id              String   @id @default(uuid()) @db.Uuid
  profileKey      String   @unique                 // Hermes profile key: "default", "leland-staff"
  name            String                           // Display name: "Leland Staff Agent"
  description     String?                          // What this agent profile does
  roleKey         String                           // references Role.key (not enforced by FK)
  status          String   @default("active")      // "active" | "inactive" | "error"
  model           String?                          // e.g. "gpt-5.2-mini"
  provider        String?                          // e.g. "openai"
  lastHealthCheck DateTime?                        // last time the profile was pinged
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([roleKey])
  @@map("agent_profiles")
}

// ---------------------------------------------------------------------------
// Cron jobs — scheduled tasks managed through the chat interface
// ---------------------------------------------------------------------------

model CronJob {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  prompt      String
  schedule    String
  skills      String[] @default([])
  isActive    Boolean  @default(true)
  lastRunAt   DateTime?
  lastResult  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cron_jobs")
}